<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data noupdate="1">
<!--    Scheduled action to auto-reconcile bank statement lines.
        Inactive by default; the admin enables it once reconciliation models
        / matching expectations are set up. -->
        <record id="ir_cron_bank_auto_reconcile" model="ir.cron">
            <field name="name">Auto-Reconcile Bank Statement Lines</field>
            <field name="model_id" ref="account.model_account_bank_statement_line"/>
            <field name="state">code</field>
            <field name="code">model._cron_auto_reconcile()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="active" eval="False"/>
        </record>
    </data>
</odoo>
