<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data noupdate="1">
<!--    Scheduled action to email due customer follow-ups.
        Inactive by default so it never emails customers unexpectedly on
        install; the admin enables it once follow-up levels are configured. -->
        <record id="ir_cron_send_followups" model="ir.cron">
            <field name="name">Send Customer Follow-ups</field>
            <field name="model_id" ref="base.model_res_partner"/>
            <field name="state">code</field>
            <field name="code">model._cron_send_followups()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="active" eval="False"/>
        </record>
    </data>
</odoo>
