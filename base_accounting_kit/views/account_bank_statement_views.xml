<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
<!--  Account Bank Statement Form View  -->
    <record id="account_bank_statement_view_form"
            model="ir.ui.view">
        <field name="name">account.bank.statement.view.form</field>
        <field name="model">account.bank.statement</field>
        <field name="priority">100</field>
        <field name="arch" type="xml">
            <form string="Bank Statement">
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" placeholder="e.g. BNK/2026/06"
                                   required="1"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="journal_id" readonly="1"
                                   help="Derived from the transaction lines below."/>
                            <field name="date"/>
                        </group>
                        <group>
                            <field name="balance_start"/>
                            <field name="balance_end_real"/>
                            <field name="attachment_ids"
                                   widget="many2many_binary"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Transactions" name="transactions">
                            <field name="line_ids">
                                <list editable="bottom">
                                    <field name="date"/>
                                    <field name="payment_ref"
                                           string="Label"/>
                                    <field name="partner_id"/>
                                    <field name="journal_id"
                                           domain="[('type', 'in', ('bank', 'cash'))]"/>
                                    <field name="amount"/>
                                    <field name="currency_id"
                                           column_invisible="1"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>
<!--  Re-enable creating statements from the list (base sets create=false) -->
    <record id="view_bank_statement_tree_create" model="ir.ui.view">
        <field name="name">account.bank.statement.list.allow.create</field>
        <field name="model">account.bank.statement</field>
        <field name="inherit_id" ref="account.view_bank_statement_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//list" position="attributes">
                <attribute name="create">true</attribute>
            </xpath>
        </field>
    </record>
<!--  Action Account Bank Statement  -->
    <record id="action_bank_statement_create_form_bank_reconcile_widget"
            model="ir.actions.act_window">
        <!-- Binding removed since the same can be achieved with multi-edit -->
        <field name="name">Create Statement</field>
        <field name="res_model">account.bank.statement</field>
        <field name="view_mode">form</field>
        <field name="view_id"
               ref="account_bank_statement_view_form"/>
        <field name="target">new</field>
    </record>

</odoo>
