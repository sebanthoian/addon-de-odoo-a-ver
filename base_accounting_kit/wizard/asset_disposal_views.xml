<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="asset_dispose_view_form" model="ir.ui.view">
        <field name="name">asset.dispose.view.form</field>
        <field name="model">asset.dispose</field>
        <field name="arch" type="xml">
            <form string="Sell or Dispose">
                <field name="asset_id" invisible="1"/>
                <field name="currency_id" invisible="1"/>
                <group>
                    <field name="disposal_type" widget="radio"/>
                    <field name="date"/>
                    <field name="sale_value"
                           invisible="disposal_type != 'sale'"
                           required="disposal_type == 'sale'"/>
                    <field name="sale_account_id"
                           invisible="disposal_type != 'sale'"
                           required="disposal_type == 'sale'"/>
                </group>
                <footer>
                    <button name="action_dispose" type="object" string="Confirm"
                            class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary"
                            special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
