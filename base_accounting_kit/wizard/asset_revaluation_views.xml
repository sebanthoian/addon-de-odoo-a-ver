<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="asset_revaluation_view_form" model="ir.ui.view">
        <field name="name">asset.revaluation.view.form</field>
        <field name="model">asset.revaluation</field>
        <field name="arch" type="xml">
            <form string="Modify Asset Value">
                <field name="asset_id" invisible="1"/>
                <field name="currency_id" invisible="1"/>
                <group>
                    <field name="value_increase"/>
                    <field name="date"/>
                    <field name="account_id"/>
                </group>
                <footer>
                    <button name="action_revaluate" type="object"
                            string="Confirm" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary"
                            special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
